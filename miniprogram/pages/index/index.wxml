<view class="page">
  <view class="hero-card">
    <view class="hero-copy">
      <view class="hero-title-accent">代码肌</view>
      <view class="hero-title-dark">欢迎您来到</view>
      
      <view class="hero-desc">持续生长的体育空间</view>

      <view class="hero-indicator">
        <view class="hero-indicator-line"></view>
        <view class="hero-indicator-dot"></view>
      </view>
    </view>

    <image
      wx:if="{{heroImageUrl}}"
      class="hero-image"
      src="{{heroImageUrl}}"
      mode="aspectFit"
    />

    <view class="hero-spark hero-spark-one">✦</view>
    <view class="hero-spark hero-spark-two">✦</view>
  </view>

  <view class="action-card" >
    <view class="action-copy">
      <view class="action-title">今天，想解决什么问题？</view>
      <view class="action-desc">选择一个工具，开始探索。</view>

      <view class="action-button" catchtap="showExploreToast">
        <text>去探索</text>
        <text class="action-button-arrow">→</text>
      </view>
    </view>

    <view class="action-visual">
      <view class="visual-orbit visual-orbit-left"></view>
      <view class="visual-orbit visual-orbit-right"></view>
      <view class="visual-panel">
        <view class="visual-panel-top">
          <view class="visual-panel-line visual-panel-line-short"></view>
          <view class="visual-panel-line"></view>
        </view>
        <view class="visual-panel-body">
          <view class="visual-panel-search">
            <view class="visual-panel-search-handle"></view>
          </view>
          <view class="visual-panel-bars">
            <view class="visual-bar visual-bar-one"></view>
            <view class="visual-bar visual-bar-two"></view>
            <view class="visual-bar visual-bar-three"></view>
          </view>
        </view>
      </view>
      <view class="visual-base visual-base-outer"></view>
      <view class="visual-base visual-base-inner"></view>
    </view>
  </view>

  <view class="section-card">
    <view class="section-head">
      <view class="section-tag">
        <text class="section-tag-icon">⚡</text>
        <text>快捷入口</text>
      </view>
      <view class="section-title">常用功能放在第一屏，操作更高效</view>
    </view>

    <view class="quick-grid">
      <view
        class="quick-card"
        wx:for="{{quickCards}}"
        wx:key="title"
        bindtap="handleQuickCard"
        data-path="{{item.path}}"
      >
        <view class="quick-icon" style="background: {{item.iconBg}}; color: {{item.iconColor}};">
          {{item.icon}}
        </view>
        <view class="quick-title">{{item.title}}</view>
        <view class="quick-desc">{{item.desc}}</view>
        <view class="quick-arrow">›</view>
      </view>
    </view>
  </view>
</view>
