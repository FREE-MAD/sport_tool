/** pages/tool/tool_f/tool_f_detailed/tool_f_detailed.wxss **/

.container {
  min-height: 100vh;
  background: #f5f6fb;
  padding: 26rpx 24rpx 72rpx;
  box-sizing: border-box;
}

.hero-card {
  position: relative;
  margin-bottom: 32rpx;
  padding-bottom: 132rpx;
}

.hero-panel {
  position: relative;
  height: 380rpx;
  border-radius: 34rpx;
  background: linear-gradient(135deg, #5d69f6 0%, #6a74f7 45%, #7d84fb 100%);
  overflow: hidden;
  box-shadow: 0 24rpx 60rpx rgba(93, 105, 246, 0.22);
}

.hero-decor {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.hero-decor-large {
  width: 230rpx;
  height: 230rpx;
  right: -58rpx;
  top: 30rpx;
}

.hero-decor-small {
  width: 120rpx;
  height: 120rpx;
  left: -34rpx;
  bottom: -46rpx;
  background: rgba(255, 255, 255, 0.08);
}

.hero-decor-line {
  position: absolute;
  top: 148rpx;
  right: 72rpx;
  width: 94rpx;
  height: 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
}

.score-card {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  bottom: 34rpx;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 32rpx 24rpx 30rpx;
  text-align: center;
  box-shadow: 0 18rpx 40rpx rgba(52, 65, 118, 0.12);
}

.total-label {
  font-size: 24rpx;
  color: #8a90a6;
  line-height: 1.2;
}

.total-score {
  margin-top: 8rpx;
  font-size: 86rpx;
  font-weight: 800;
  line-height: 1;
  color: #111a34;
  letter-spacing: -2rpx;
}

.header {
  margin-bottom: 24rpx;
}

.subtitle {
  display: block;
  padding: 18rpx 26rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.86);
  color: #8d93a8;
  font-size: 24rpx;
  line-height: 1.4;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(33, 41, 76, 0.04);
}

.section {
  margin-bottom: 24rpx;
  padding: 30rpx 24rpx 18rpx;
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 36rpx rgba(33, 41, 76, 0.05);
}

.section-title {
  font-size: 46rpx;
  font-weight: 800;
  color: #121a33;
  line-height: 1.15;
}

.section-hint {
  margin-top: 10rpx;
  margin-bottom: 24rpx;
  font-size: 24rpx;
  color: #c0c4d0;
  line-height: 1.3;
}

.score-list {
  display: flex;
  flex-direction: column;
}

.score-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 0;
}



.item-left {
  flex: 1;
  min-width: 0;
  padding-right: 24rpx;
}

.item-name {
  font-size: 30rpx;
  color: #6f768d;
  line-height: 1.45;
  word-break: break-all;
}

.item-right {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  flex-shrink: 0;
}

.item-detail {
  font-size: 26rpx;
  color: #656d85;
  line-height: 1.3;
}

.item-score {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.1;
  color: #2c365a;
}

.ai-section {
  border: 2rpx solid #ebe1a8;
  background: #fffef5;
}

.ai-title {
  color: #a77b00;
}

.ai-content {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.7;
  white-space: pre-wrap;
  padding: 8rpx 0;
}
