/** pages/tool/tool_f/tool_f.wxss **/

/* ==========================================
   整体布局
   ========================================== */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #e8f4fd 0%, #f0f7e8 30%, #fef9e7 60%, #fce4ec 100%);
  padding: 24rpx 24rpx 60rpx;
  box-sizing: border-box;
}

/* ==========================================
   顶部 Header
   ========================================== */
.header {
  text-align: center;
  padding: 50rpx 0 30rpx;
  position: relative;
}

.header::after {
  content: '';
  display: block;
  width: 80rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #07c160, #00d4aa, #07c160);
  border-radius: 3rpx;
  margin: 20rpx auto 0;
}

.title {
  font-size: 44rpx;
  font-weight: 800;
  color: #1a1a2e;
  letter-spacing: 4rpx;
  text-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.15);
}

.subtitle {
  font-size: 26rpx;
  color: #8e8e93;
  margin-top: 12rpx;
  letter-spacing: 1rpx;
}

/* ==========================================
   表单卡片
   ========================================== */
.form {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 36rpx 28rpx 24rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.06), 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
  position: relative;
  overflow: hidden;
}

.form::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #07c160, #00d4aa, #576b95, #07c160);
  border-radius: 0 0 50% 50%;
}

/* ==========================================
   分区区块
   ========================================== */
.section-block {
  margin-bottom: 20rpx;
  padding-bottom: 6rpx;
}

.section-block:last-child {
  margin-bottom: 0;
}

/* ==========================================
   分区标题
   ========================================== */
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin: 36rpx 0 24rpx;
  padding-left: 20rpx;
  border-left: 6rpx solid #07c160;
  line-height: 1.4;
  position: relative;
}

.section-title::after {
  content: '';
  display: inline-block;
  width: 8rpx;
  height: 8rpx;
  background-color: #07c160;
  border-radius: 50%;
  margin-left: 12rpx;
  vertical-align: middle;
  opacity: 0.5;
}

.special-group-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #576b95;
  margin: 30rpx 0 15rpx;
  padding-left: 20rpx;
  border-left: 4rpx solid #576b95;
  line-height: 1.4;
}

/* ==========================================
   表单项
   ========================================== */
.form-item {
  margin-bottom: 28rpx;
}

/* ==========================================
   标签
   ========================================== */
.label {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 14rpx;
  display: flex;
  align-items: center;
}

.label::before {
  content: '';
  display: inline-block;
  width: 10rpx;
  height: 10rpx;
  background-color: #07c160;
  border-radius: 50%;
  margin-right: 10rpx;
  flex-shrink: 0;
}

/* ==========================================
   输入框
   ========================================== */
.input {
  width: 100%;
  height: 84rpx;
  background-color: #f7f8fa;
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: #1a1a2e;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.input:focus {
  border-color: #07c160;
  background-color: #f0fdf4;
  box-shadow: 0 0 0 6rpx rgba(7, 193, 96, 0.08);
}

.input::placeholder {
  color: #c0c0c0;
  font-size: 26rpx;
}

/* ==========================================
   选择器
   ========================================== */
.picker {
  width: 100%;
  height: 84rpx;
  background: linear-gradient(135deg, #f7f8fa 0%, #f0f1f5 100%);
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: #1a1a2e;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  border: 2rpx solid #ebedf0;
  transition: all 0.2s ease;
}

.picker:active {
  border-color: #07c160;
  background: linear-gradient(135deg, #f0fdf4 0%, #e8f8f0 100%);
}

.arrow {
  font-size: 20rpx;
  color: #07c160;
  margin-left: 12rpx;
  transition: transform 0.2s ease;
}

/* ==========================================
   提交按钮
   ========================================== */
.submit-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #07c160 0%, #05d08a 50%, #00d4aa 100%);
  color: #fff;
  font-size: 34rpx;
  font-weight: 700;
  border-radius: 48rpx;
  margin-top: 44rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.3);
  letter-spacing: 4rpx;
  transition: all 0.2s ease;
}

.submit-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.2);
}

.submit-btn[disabled] {
  background: linear-gradient(135deg, #c8e6c9 0%, #b2dfdb 100%);
  color: rgba(255, 255, 255, 0.8);
  box-shadow: none;
}

/* ==========================================
   重置按钮
   ========================================== */
.reset-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #fff;
  color: #8e8e93;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 40rpx;
  margin-top: 20rpx;
  border: 2rpx solid #e8e8ed;
  transition: all 0.2s ease;
}

.reset-btn:active {
  background-color: #f7f8fa;
  border-color: #d0d0d5;
  color: #666;
}
