/** pages/tool/tool_f/tool_f.wxss **/

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #eef4fb 0%, #f6f8fc 220rpx, #f3f5f9 100%);
  padding: 28rpx 24rpx 56rpx;
  box-sizing: border-box;
}

.hero-card {
  padding: 44rpx 16rpx 28rpx;
}

.hero-kicker {
  font-size: 26rpx;
  font-weight: 700;
  color: #1f2a44;
  line-height: 1.4;
}

.hero-title {
  margin-top: 10rpx;
  font-size: 56rpx;
  font-weight: 800;
  color: #1f2a44;
  line-height: 1.2;
}

.hero-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #8a93a5;
  line-height: 1.6;
}

.content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.section-card {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 30rpx;
  padding: 28rpx;
  box-shadow: 0 14rpx 36rpx rgba(42, 57, 92, 0.08);
}

.section-card--action {
  padding-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  align-items: stretch;
}

.preference-action-row {
  display: flex;
  gap: 14rpx;
  align-items: center;
}

.primary-action-row {
  display: flex;
  gap: 14rpx;
  align-items: center;
}

.section-head {
  margin-bottom: 24rpx;
}

.section-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 40rpx;
  padding: 0 18rpx;
  margin-bottom: 14rpx;
  border-radius: 999rpx;
  background: #fff4df;
  color: #d9892b;
  font-size: 22rpx;
  font-weight: 700;
}

.section-title {
  font-size: 38rpx;
  font-weight: 800;
  color: #1f2a44;
  line-height: 1.3;
}

.section-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #a1a9b8;
  line-height: 1.5;
}

.field-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 22rpx;
}

.field-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.field-row--stack {
  align-items: flex-start;
}

.field-row--aux-type {
  margin-bottom: 16rpx;
}

.field-label {
  width: 112rpx;
  flex-shrink: 0;
  font-size: 28rpx;
  font-weight: 700;
  color: #5c667b;
  line-height: 1.4;
}

.field-label--block {
  padding-top: 18rpx;
}

.field-picker {
  flex: 1;
  min-width: 0;
}

.option-group {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.option-group--row {
  /* flex-wrap: nowrap; */
  gap: 8rpx;
}

.option-group--row .option-btn {
  flex: 0 1 148rpx;
  min-width: 0;
  padding: 0 12rpx;
}

.option-group--adaptive .option-btn {
  flex: 0 0 auto;
  width: auto;
  max-width: 100%;
  padding: 0 24rpx;
}

.option-btn {
  margin: 0;
  min-width: 168rpx;
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  border: 2rpx solid #e3e8f2;
  background: #ffffff;
  color: #5f6b81;
  font-size: 28rpx;
  font-weight: 700;
  white-space: nowrap;
}

.s-v {
  overflow-x: auto;
  overflow-y: hidden;
  -webkit-overflow-scrolling: touch;
}

.s-v .option-group--row {
  flex-wrap: nowrap;
  width: max-content;
  min-width: 100%;
}

.s-v .option-group--row .option-btn {
  flex: 0 0 auto;
  width: auto;
  padding: 0 24rpx;
}

.option-group--special-type {
  margin-bottom: 30rpx;
}

.option-btn--active {
  border-color: #c8d3ff;
  background: #eef1ff;
  color: #6678ff;
  box-shadow: 0 8rpx 18rpx rgba(102, 120, 255, 0.12);
}

.option-btn::after {
  border: none;
}

.select-shell {
  min-height: 88rpx;
  border-radius: 22rpx;
  padding: 0 26rpx;
  background: #ffffff;
  border: 2rpx solid #e5eaf4;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
}

.select-shell--soft {
  background: #f6f8ff;
  border-color: #dce4ff;
}

.select-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #25314b;
  line-height: 1.4;
}

.select-arrow {
  margin-left: 20rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #9aa5bc;
  line-height: 1;
}

.score-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.score-card {
  background: #f5f8ff;
  border: 2rpx solid #dce5fb;
  border-radius: 24rpx;
  padding: 22rpx;
}

.score-card--plain {
  background: #ffffff;
}

.score-meta {
  margin-bottom: 18rpx;
}

.score-name {
  font-size: 34rpx;
  font-weight: 800;
  color: #24314b;
  line-height: 1.3;
}

.score-hint {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #95a0b5;
  line-height: 1.5;
  white-space: pre-wrap;
}

.score-field {
  min-height: 82rpx;
  background: #ffffff;
  border-radius: 20rpx;
  border: 2rpx solid #e6ebf5;
  padding: 0 22rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.score-field--main-choice {
  margin-top: 16rpx;
}

.score-field--compact {
  min-height: 76rpx;
}

.score-input {
  flex: 1;
  height: 82rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #25314b;
}

.score-input::placeholder {
  color: #b0b8c8;
  font-size: 28rpx;
  font-weight: 600;
}

.score-unit {
  flex-shrink: 0;
  min-width: 54rpx;
  height: 44rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #f1f4fb;
  color: #9aa5bc;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.multi-input-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.multi-input-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.multi-input-label {
  width: 120rpx;
  flex-shrink: 0;
  font-size: 26rpx;
  font-weight: 700;
  color: #667289;
}

.multi-input-item .score-field {
  flex: 1;
}

.notice-card {
  background: #f7f8fc;
  border-radius: 22rpx;
  padding: 22rpx 24rpx;
}

.notice-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #27324c;
  line-height: 1.3;
}

.notice-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8f98aa;
  line-height: 1.6;
}

.submit-btn {
  flex: 1;
  min-height: 0;
  padding: 0;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 999rpx;
  border: none;
  background: linear-gradient(90deg, #6d79ff 0%, #7284ff 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
  box-shadow: 0 8rpx 16rpx rgba(109, 121, 255, 0.15);
}

.preference-btn {
  flex: 1;
  min-height: 0;
  padding: 0;
  height: 68rpx;
  line-height: 68rpx;
  border-radius: 999rpx;
  border: 2rpx solid #d9e0f5;
  background: #ffffff;
  color: #5f6f92;
  font-size: 26rpx;
  font-weight: 700;
}

.preference-btn--danger {
  border-color: #f0d8d8;
  background: #fff7f7;
  color: #c46b6b;
}

.submit-btn[disabled] {
  background: linear-gradient(90deg, #c7cffc 0%, #cfd7ff 100%);
  color: rgba(255, 255, 255, 0.92);
  box-shadow: none;
}

.reset-btn {
  flex: 1;
  min-height: 0;
  padding: 0;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 999rpx;
  border: 2rpx solid #dde1f0;
  background: #f5f7fc;
  color: #7d879c;
  font-size: 28rpx;
  font-weight: 700;
}

.submit-btn::after,
.reset-btn::after,
.preference-btn::after {
  border: none;
}
