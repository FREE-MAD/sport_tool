/** pages/tool/tool_f/tool_f.wxss **/
.container {
  min-height: 100vh;
  background-color: #f6f6f6;
  padding: 30rpx;
  box-sizing: border-box;
}

.header {
  text-align: center;
  padding: 40rpx 0 30rpx;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
}

.subtitle {
  font-size: 26rpx;
  color: #999;
  margin-top: 10rpx;
}

.form {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 2rpx 20rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #07c160;
  margin: 30rpx 0 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #07c160;
}

.form-item {
  margin-bottom: 30rpx;
}

.label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
}

.code-tag {
  font-size: 22rpx;
  color: #999;
  background-color: #f0f0f0;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  margin-left: 12rpx;
  font-weight: normal;
}

.input {
  width: 100%;
  height: 80rpx;
  background-color: #f6f6f6;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.picker {
  width: 100%;
  height: 80rpx;
  background-color: #f6f6f6;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.arrow {
  font-size: 22rpx;
  color: #999;
}

.submit-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  background-color: #07c160;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 45rpx;
  margin-top: 40rpx;
  border: none;
}

.submit-btn[disabled] {
  background-color: #a0e8c0;
}

.reset-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #fff;
  color: #999;
  font-size: 28rpx;
  border-radius: 45rpx;
  margin-top: 20rpx;
  border: 1rpx solid #e0e0e0;
}
