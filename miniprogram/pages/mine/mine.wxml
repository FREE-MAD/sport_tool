<view class="page">
  <view class="hero-card">
    <view class="hero-head">
      <view class="hero-badge">个人中心</view>
      <view wx:if="{{hasUserInfo}}" class="hero-status hero-status--active">已授权</view>
      <view wx:else class="hero-status">待授权</view>
    </view>

    <view class="profile-row">
      <view class="avatar-shell">
        <block wx:if="{{hasUserInfo}}">
          <image class="userinfo-avatar" src="{{userInfo.avatarUrl}}" mode="cover"></image>
        </block>
        <block wx:else>
          <view class="avatar-placeholder">我</view>
        </block>
      </view>

      <view class="profile-copy">
        <block wx:if="{{hasUserInfo}}">
          <view class="profile-name">{{userInfo.nickName}}</view>
          <view class="profile-desc">头像与昵称已同步，这里会继续作为你的常用页面入口。</view>
        </block>
        <block wx:else>
          <view class="profile-name">未授权用户</view>
          <view class="profile-desc">先获取头像昵称也可以，直接使用下方快捷入口也可以。</view>
        </block>
      </view>
    </view>

    <button
      class="profile-btn"
      wx:if="{{!hasUserInfo && canIUseGetUserProfile}}"
      bindtap="getUserProfile"
    >
      获取头像昵称
    </button>
    <button
      class="profile-btn"
      wx:elif="{{!hasUserInfo}}"
      open-type="getUserInfo"
      bindgetuserinfo="getUserInfo"
    >
      获取头像昵称
    </button>

    <view class="profile-stats">
      <view class="stat-card" wx:for="{{stats}}" wx:key="label">
        <view class="stat-value">{{item.value}}</view>
        <view class="stat-label">{{item.label}}</view>
      </view>
    </view>
  </view>

  <view class="section-card">
    <view class="section-head">
      <view class="section-tag">常用入口</view>
      <view class="section-title">把高频动作收在这一屏</view>
      <view class="section-desc">个人中心不只展示信息，也保留你最常回去的两个核心页面。</view>
    </view>

    <view class="quick-grid">
      <view
        class="quick-card"
        wx:for="{{quickMenus}}"
        wx:key="title"
        bindtap="handleMenuTap"
        data-path="{{item.path}}"
        data-type="{{item.type}}"
        data-message="{{item.message}}"
      >
        <view class="quick-card-top">
          <view class="quick-icon" style="background: {{item.iconBg}}; color: {{item.iconColor}};">
            {{item.icon}}
          </view>
          <view class="quick-badge">{{item.badge}}</view>
        </view>
        <view class="quick-title">{{item.title}}</view>
        <view class="quick-desc">{{item.desc}}</view>
        <view class="quick-arrow">›</view>
      </view>
    </view>
  </view>

